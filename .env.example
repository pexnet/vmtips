# VMTips Environment Variables
# Copy this file to .env and fill in real values

# Required: JWT signing secret — MUST change in production!
JWT_SECRET_KEY=change-me-in-production

# Optional: Admin user ID (fallback is user ID 1)
ADMIN_USER_ID=1

# Optional: Admin email
ADMIN_EMAIL=admin@example.com

# Optional: Admin password (defaults to 'admin' — CHANGE IN PRODUCTION!)
ADMIN_PASSWORD=admin

# Optional: Comma-separated CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: Database URL (SQLite path)
DATABASE_URL=sqlite:///app/data/vmtips.db

# Optional: Static files directory (frontend build output)
STATIC_DIR=/app/static

# Optional: World Cup JSON API URL
WORLD_CUP_JSON_URL=https://worldcupjson.net/matches

# Optional: OpenFootball static schedule URL (used as fallback/primary when tournament starts)
OPENFOOTBALL_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json

# Optional: Sync source — "worldcupjson" or "openfootball"
SYNC_SOURCE=worldcupjson

# Optional: Enable automatic scheduled sync (toggle to True once tournament starts)
AUTO_SYNC_ENABLED=false

# Optional: Auto-sync interval in minutes (default 5)
AUTO_SYNC_INTERVAL_MINUTES=5